{
  "name": "maestro",
  "version": "0.0.1",
  "description": "Parallel coding-agent orchestrator — run CLI coding agents in isolated Git worktrees and review/merge their work from one UI.",
  "author": "Maestro",
  "license": "MIT",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "postinstall": "node scripts/fix-node-pty.cjs",
    "fix:node-pty": "node scripts/fix-node-pty.cjs",
    "build": "npm run typecheck && electron-vite build",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:dir": "npm run build && electron-builder --dir",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "screenshots": "tsx scripts/screenshot.ts",
    "smoke:m1": "tsx scripts/module1-smoke.ts",
    "smoke:m2": "tsx scripts/module2-smoke.ts",
    "smoke:m3": "tsx scripts/module3-smoke.ts",
    "smoke:m4b": "tsx scripts/module4b-smoke.ts",
    "smoke:m5": "tsx scripts/module5-smoke.ts",
    "smoke:m6": "tsx scripts/module6-smoke.ts",
    "smoke:m7": "tsx scripts/module7-smoke.ts",
    "smoke:m8": "tsx scripts/module8-smoke.ts",
    "smoke:m9": "tsx scripts/module9-smoke.ts",
    "smoke:m10": "tsx scripts/module10-smoke.ts",
    "smoke:m11": "tsx scripts/module11-smoke.ts",
    "smoke:m12": "tsx scripts/module12-smoke.ts",
    "smoke:m13": "tsx scripts/module13-smoke.ts",
    "smoke:m14": "tsx scripts/module14-smoke.ts",
    "rebuild:electron": "electron-rebuild -f -o better-sqlite3",
    "rebuild:node": "npm rebuild better-sqlite3"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@types/dagre": "^0.7.54",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.11.2",
    "better-sqlite3": "^11.10.0",
    "dagre": "^0.8.5",
    "execa": "^5.1.1",
    "monaco-editor": "^0.52.2",
    "node-pty": "^1.1.0",
    "react-is": "^19.2.7",
    "recharts": "^3.9.2",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "playwright": "^1.61.1",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
